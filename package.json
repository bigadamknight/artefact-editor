{
  "name": "artefact-editor",
  "private": true,
  "version": "0.1.0",
  "description": "Direct-manipulation editor for AI-generated artefacts — HTML web apps, hyperframes videos, PIL marketing graphics.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:core": "yarn workspace @artefact-editor/core build",
    "build:adapter-html": "yarn workspace @artefact-editor/adapter-html build",
    "build:adapter-image-template": "yarn workspace @artefact-editor/adapter-image-template build",
    "build:packages": "yarn build:core && yarn build:adapter-html && yarn build:adapter-image-template",
    "build:web": "yarn workspace @artefact-editor/web build",
    "build": "yarn build:packages && yarn build:web",
    "typecheck": "yarn workspaces run typecheck",
    "dev:cli": "yarn workspace @artefact-editor/cli dev",
    "dev:web": "yarn workspace @artefact-editor/web dev",
    "dev": "yarn build:packages && concurrently -n cli,web -c blue,magenta \"yarn dev:cli\" \"yarn dev:web\"",
    "start": "yarn workspace @artefact-editor/cli start"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "typescript": "^5.6.3"
  },
  "packageManager": "yarn@1.22.22"
}
